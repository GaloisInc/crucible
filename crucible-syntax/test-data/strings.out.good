(defun @test-str () (String Unicode)
   (start start:
      (let x "a")
      (let y "\\")
      (let q "\"")
      (let w "\t\n ")
      (let e (string-empty Unicode))
      (let c (string-concat x y))
      (let n (string-length x))
      (return x)))

test-str
%0
  % 5:12
  $0 = stringLit("a")
  % 6:12
  $1 = stringLit("\\")
  % 7:12
  $2 = stringLit("\"")
  % 8:12
  $3 = stringLit("\t\n ")
  % 9:12
  $4 = stringEmpty(UnicodeRepr)
  % 10:12
  $5 = stringConcat(UnicodeRepr, $0, $1)
  % 11:12
  $6 = stringLength($0)
  % 12:5
  return $0
  % no postdom
